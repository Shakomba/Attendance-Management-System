+        bw = max(1, right - left)
+        bh = max(1, bottom - top)
+        x, y = left, top
+
+        src_h, src_w = frame_bgr.shape[:2]
+
+        # Clamp scale so crop stays within frame
+        sc = min((src_h - 1) / bh, min((src_w - 1) / bw, scale))
